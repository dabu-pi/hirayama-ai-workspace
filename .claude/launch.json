{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "training-platform-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "training-program-platform-jp"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "workout-prototype",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "training-program-platform-jp/web/prototypes", "-p", "3333", "--no-clipboard"],
      "port": 3333
    },
    {
      "name": "patient-management",
      "runtimeExecutable": "python",
      "runtimeArgs": ["patient-management/app.py"],
      "port": 5000
    },
    {
      "name": "sandbox-flask-test",
      "runtimeExecutable": "python",
      "runtimeArgs": ["archive/sandbox-flask-test/app.py"],
      "port": 5000
    }
  ]
}
