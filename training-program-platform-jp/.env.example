# ============================================================
# 環境変数テンプレート
# 実際の値は .env.local に設定し、このファイルはコミットしても安全
# ============================================================

# Supabase プロジェクト URL（必須）
# Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon (public) key（必須）
# Supabase Dashboard → Project Settings → API → Project API Keys → anon public
# RLS が有効なため、公開しても DB 操作はポリシーで制限される
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key（必須）
# Supabase Dashboard → Project Settings → API → Project API Keys → service_role secret
# ⚠️ サーバー側のみで使用。NEXT_PUBLIC_ プレフィックスをつけないこと
# ⚠️ 絶対に .env.local 以外のファイルに実際の値を書かないこと
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
