# Cloud Build コンテキストから除外（Dockerfile で明示COPYしているファイルのみ必要）
.gcloudignore
.git
.gitignore
.claspignore

# Python 仮想環境・キャッシュ（最大サイズ削減）
.venv/
__pycache__/
*.pyc
*.pyo

# GAS・clasp 関連（Cloud Run 不要）
*.js
appsscript.json
.clasp.json

# ドキュメント・仕様
*.md
docs/
*.pdf

# テスト・ログ
tests/
logs/
output/

# 認証情報（絶対除外）
secrets/
*.json
!requirements.txt

# その他不要ファイル
*.xlsx.bak
*.cmd
*.cfg
node_modules/
