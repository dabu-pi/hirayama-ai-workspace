# 認証情報・秘密情報
.env
*.env
service_account.json
credentials.json
token.json

# Python
__pycache__/
*.py[cod]
venv/
.venv/
*.egg-info/

# Node.js
node_modules/

# IDE・エディタ
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
desktop.ini

# 一時ファイル
~$*
*.tmp
*.bak
tmp/

# ログ・一時ファイル
flask_log.txt
*.log
nul

# GAS clasp
.clasp.json

# ============================================================
# プロジェクトログ自動生成（run-with-log.ps1 / note.ps1）
# ============================================================
# 実行ログ・エラーログ・成果物はgit管理外
*/logs/run/
*/logs/error/
*/artifacts/
# logs/notes/ はgit管理対象のため除外しない

# ルートレベルの一時ログ
_logs/

# logs: keep notes only (tracked), ignore others
logs/
!logs/notes/
!logs/notes/**
!logs/runlog/
logs/run/
logs/error/
logs/artifacts/
logs/runlog/**
logs/*.log

# root artifacts (debug reports etc.)
artifacts/

# local-only settings
.claude/settings.local.json

# Claude Code 内部ディレクトリ（worktrees はリポジトリに含めない）
.claude/worktrees/

# local secrets
secrets/

# STRONG DEPOT 実データのローカル専用フルエクスポート
projects/machine-sales-rebuild/data/raw/*.full.csv
projects/machine-sales-rebuild/data/output/product_master_v0.full.csv
projects/machine-sales-rebuild/data/output/*.full.log
projects/machine-sales-rebuild/tmp/*
!projects/machine-sales-rebuild/tmp/.gitkeep
.uv-cache/

# 参考資料PDF（制度資料など。Git管理対象外・ローカル保持）
gas-projects/**/*.pdf

# 申請書出力・転記バッチ（患者個人情報を含むためGit管理外）
gas-projects/**/output/**/*.xlsx
gas-projects/**/transfer_batch*.ndjson

