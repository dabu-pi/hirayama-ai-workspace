# 認証情報・秘密情報
.env
*.env
service_account.json
credentials.json
token.json

# Python
__pycache__/
*.py[cod]
venv/
.venv/
*.egg-info/

# Node.js
node_modules/

# IDE・エディタ
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
desktop.ini

# 一時ファイル
~$*
*.tmp
*.bak

# ログ・一時ファイル
flask_log.txt
*.log
nul

# GAS clasp
.clasp.json

# ============================================================
# プロジェクトログ自動生成（run-with-log.ps1 / note.ps1）
# ============================================================
# 実行ログ・エラーログ・成果物はgit管理外
*/logs/run/
*/logs/error/
*/artifacts/
# logs/notes/ はgit管理対象のため除外しない

# ルートレベルの一時ログ
_logs/

# logs: keep notes only (tracked), ignore others
logs/
!logs/notes/
!logs/notes/**
!logs/runlog/
logs/run/
logs/error/
logs/artifacts/
logs/runlog/**
logs/*.log

# root artifacts (debug reports etc.)
artifacts/

# local-only settings
.claude/settings.local.json

# local secrets
secrets/

