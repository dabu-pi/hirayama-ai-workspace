# AIOS Dual-Agent Orchestrator — 環境変数テンプレート
#
# このファイルをコピーして .env を作成してください。
#   cp .env.example .env
#
# .env は gitignore 済みのためコミットしないでください。

# ─── OpenAI ───────────────────────────────────────
OPENAI_API_KEY=

# 使用するモデル（未設定時は openai_client.py のデフォルトが使われる）
OPENAI_MODEL=gpt-4o

# ─── Anthropic ────────────────────────────────────
ANTHROPIC_API_KEY=

# 使用するモデル（未設定時は anthropic_client.py のデフォルトが使われる）
ANTHROPIC_MODEL=claude-sonnet-4-6
